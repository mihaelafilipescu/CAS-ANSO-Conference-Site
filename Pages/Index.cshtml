        z-index: 1;
    }

    .hero-content-panel {
        max-width: 900px;
        padding: 2rem 2.25rem;
        border-radius: 36px;
        background: rgba(255, 255, 255, 0.10);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
