                            </div>
                            <div class="org-name">ICF (“Ilie Murgulescu”)</div>
                            <div class="org-role">
                                Primary organizer
                            </div>
                        </div>
                    </div>

                    <!-- SASA -->
                    <div class="col-12 col-md-6 col-lg-6">
                        <div class="org-card h-100">
                            <div class="org-logo">
                                <img src="/img/logos/sasa.png" alt="SASA logo" />
                            </div>
                            <div class="org-name">SASA</div>
                            <div class="org-role">
                                Co-host · Program contribution · Session moderation
                            </div>
                        </div>
                    </div>

                    <!-- ANSO -->
                    <div class="col-12 col-md-6 col-lg-6">
                        <div class="org-card h-100">
                            <div class="org-logo">
                                <img src="/img/logos/anso-nobg.png" alt="ANSO logo" />
                            </div>
                            <div class="org-name">ANSO</div>
                            <div class="org-role">
                                Strategic partner · Support
                            </div>
                        </div>
                    </div>
                </div>

                <hr class="my-5" />

                <header class="text-center mb-3">
                    <h2 class="h4 fw-semibold mb-1">Sponsors</h2>
                    <p class="text-secondary mb-0">TBD</p>
                </header>

            </div>
        </div>
    </div>
</section>

<style>
    .org-card {
        background: #fff;
        border: 1px solid rgba(0,0,0,.10);
        border-radius: 16px;
        padding: 28px 24px;
        min-height: 300px;
        text-align: center;
        box-shadow: 0 .35rem 1rem rgba(0,0,0,.05);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
