@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<!-- HERO (wide + ready for background image) -->
<section class="hero-academic d-flex align-items-center border-bottom">
    <div class="container-fluid px-0">
        <div class="container">
            <div class="row justify-content-center">
                <div class="col-12 col-xl-10">
                    <div class="text-center py-5 py-lg-6">
                        <div class="hero-content-panel mx-auto">
                            <h1 class="hero-title mb-3">CAS–ANSO Conference</h1>

                            <p class="hero-subtitle mb-4 mx-auto" style="max-width: 52rem;">
                                A scientific conference dedicated to research exchange, interdisciplinary dialogue,
                                and international cooperation.
                            </p>

                            <div class="d-flex justify-content-center gap-2 flex-wrap">
                                <a class="btn btn-outline-dark btn-lg" asp-page="/Conference/Schedule">Schedule</a>
                                <a class="btn btn-dark btn-lg" asp-page="/Conference/Registration">Registration</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="hero-overlay"></div>
</section>

<!-- OVERVIEW + THEMES (academic, centered headings, no boxes for text) -->
<section class="py-5 bg-white">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-12 col-xl-10">

                <!-- Centered heading -->
                <header class="text-center mb-4">
                    <h2 class="h3 fw-semibold mb-2">Conference overview</h2>
                    <p class="text-secondary mb-0">
                        The CAS–ANSO Conference provides a platform for rigorous scientific exchange and interdisciplinary dialogue.
                    </p>
                </header>

                <!-- Objectives (no card) -->
                <div class="overview-block">
                    <h3 class="h4 fw-semibold mb-2">Objectives</h3>
                  
                    <ul class="text-secondary mb-0">
                        <li>
                            Promote interdisciplinary collaboration to develop integrated solutions for sustainable
                            energy and environmental resilience.
                        </li>
                        <li>
                            Showcase regional innovations with global relevance, highlighting scalable models for
                            climate adaptation and ecosystem protection.
                        </li>
                        <li>
                            Support policy and strategic dialogue aligned with international sustainability goals and
                            the EU Green Deal.
                        </li>
                        <li>
                            Advance cutting-edge materials and technologies for green energy and circular
                            economy solutions.
                        </li>
                        <li>
                            Engage diverse stakeholders to foster inclusive, just, and sustainable transitions.
                        </li>
                    </ul>
                </div>

                <!-- Relevance (no card) -->
                <div class="overview-block">
                    <h3 class="h4 fw-semibold mb-2">Relevance</h3>
                    <p class="text-secondary mb-2">
                        The ANSO-RA-SASA Conference addresses urgent global challenges related to climate change,
                        sustainable energy transition, and environmental resilience. By aligning with key international
                        priorities—including the UN Sustainable Development Goals (SDG 6, 7, and 9) and the EU Green
                        Deal—the conference provides a platform for advancing innovative, science-based solutions in
                        green energy, advanced materials, and ecosystem sustainability.
                    </p>
                    <p class="text-secondary mb-2">
                        With a strong focus on the Danube–Carpathian region as a model for scalable solutions, the
                        event fosters international collaboration across the Belt and Road regions, bridging research,
                        policy, and industry to support sustainable and high-quality development worldwide.
                    </p>
                </div>

                <hr class="my-5" />

                <!-- Centered themes heading -->
                <header class="text-center mb-4">
                    <h2 class="h3 fw-semibold mb-2">Themes</h2>
                    <p class="text-secondary mb-0">
                        The conference program is organized around the following thematic areas.
                    </p>
                </header>

                <!-- Themes grid -->
                <div class="row g-3">
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="theme-card p-5 border rounded-3 h-100 text-center d-flex flex-column justify-content-center">
                            <div class="theme-title">Sustainable Energy Conversion</div>
                            <div class="text-secondary mt-1">
                                This theme focuses on advancing renewable energy pathways and low-carbon technologies
                                through cutting-edge research in catalysis, green chemistry, and energy systems. It highlights
                                innovations such as hydrogen and ammonia energy, and efficient conversion processes aimed
                                at enabling a clean and resilient energy transition.
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="theme-card p-5 border rounded-3 h-100 text-center d-flex flex-column justify-content-center">
                            <div class="theme-title">Advanced Materials for Sustainability</div>
                            <div class="text-secondary mt-1">
                                Centered on the development of eco-friendly and high-performance materials, this theme
                                explores smart materials, functional hybrids, and circular design approaches. Emphasis is placed
                                on materials that support energy efficiency, environmental protection, and sustainable
                                industrial processes, bridging fundamental science with real-world applications.
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="theme-card p-5 border rounded-3 h-100 text-center d-flex flex-column justify-content-center">
                            <div class="theme-title">Molecular Design and Resilience</div>
                            <div class="text-secondary mt-1">
                                This theme addresses the role of molecular and nanoscale design in enhancing environmental
                                resilience. It covers bio-inspired systems, nanomaterials, environmental monitoring
                                technologies, and nature-based solutions, contributing to ecosystem adaptation, heritage
                                conservation, and sustainable resource management.
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>
</section>

<style>
    /* Spacing between Objectives/Relevance blocks */
    .overview-block {
        padding: 0;
        margin-top: 1.25rem;
    }

    /* Make theme titles more visible */
    .theme-card {
        background: #fff;
        transition: transform 160ms ease, box-shadow 160ms ease;
    }

    .theme-title {
        font-weight: 700;
        font-size: 1.05rem;
        line-height: 1.25;
        color: #111;
    }

    .theme-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.08);
    }
</style>

<style>
    .theme-card {
        background: #fff;
        transition: transform 160ms ease, box-shadow 160ms ease;
    }

        .theme-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 .5rem 1.25rem rgba(0,0,0,.08);
        }
</style>

<script>
    // "+" becomes "–" when expanded (for both boxes)
    document.addEventListener("DOMContentLoaded", () => {
        const pairs = [
            { collapseId: "collapseObjectives" },
            { collapseId: "collapseRelevance" }
        ];

        pairs.forEach(({ collapseId }) => {
            const el = document.getElementById(collapseId);
            if (!el) return;

            const btn = document.querySelector(`[data-bs-target="#${collapseId}"]`);
            const icon = btn?.querySelector(".toggle-icon");
            if (!btn || !icon) return;

            el.addEventListener("show.bs.collapse", () => icon.textContent = "–");
            el.addEventListener("hide.bs.collapse", () => icon.textContent = "+");
        });
    });
</script>

<style>
    /* HERO: pregătit pentru imagine de fundal */
    .hero-academic {
        position: relative;
        min-height: 60vh;
        background-image: url('/img/Title-trial-photo.jpg'); /* dacă ai setat-o */
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    /* Overlay mai discret (mai puțin alb) */
    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient( to bottom, rgba(255,255,255,0.30), rgba(255,255,255,0.45) );
        pointer-events: none;
        display: block;
    }

    /* Textul deasupra overlay-ului */
    .hero-academic .container {
        position: relative;
        z-index: 1;
    }

    .hero-content-panel {
        max-width: 900px;
        padding: 2rem 2.25rem;
        border-radius: 36px;
        background: rgba(255, 255, 255, 0.10);
        backdrop-filter: blur(22px);
        -webkit-backdrop-filter: blur(22px);
        border: none;
        box-shadow: none;
    }
</style>

<section class="py-5 bg-white">
    <div class="container">
