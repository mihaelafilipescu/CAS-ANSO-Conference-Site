@page
@model ConferenceSite.Pages.Conference.ScheduleModel
@{
    ViewData["Title"] = "Program";
}

<section class="schedule-page py-5">
    <div class="container">
        <header class="text-center schedule-header mb-5">
            <h1 class="schedule-title">Preliminary Schedule</h1>
            <p class="schedule-subtitle mb-0">
                23–25 September 2026 · Bucharest, Romanian Academy
            </p>
        </header>

        <div class="schedule-board">

            <!-- DAY 1 -->
            <div class="schedule-day">
                <div class="schedule-day-head">
                    <div class="schedule-day-label">Day 1</div>
                    <div class="schedule-day-theme">Strategic Foundations for Sustainability</div>
                </div>

                <div class="schedule-item">
                    <div class="schedule-time">08:30–09:00</div>
                    <div class="schedule-event">Registration</div>
                </div>

                <div class="schedule-item">
                    <div class="schedule-time">09:00–09:20</div>
                    <div class="schedule-event">Opening Ceremony</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">09:20–10:10</div>
                    <div class="schedule-event">Opening Session — Policy Frameworks and International Cooperation</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">10:10–10:20</div>
                    <div class="schedule-event">Coffee Break</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">10:20–12:40</div>
                    <div class="schedule-event">Session 1 — Materials Sciences, Green Technologies and Sustainable Energy Conversion (Part 1)</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">12:40–13:30</div>
                    <div class="schedule-event">Lunch Break</div>
                </div>

                <div class="schedule-item poster-item">
                    <div class="schedule-time">13:30–15:00</div>
                    <div class="schedule-event">Poster Session 1 · ROMPHYSCHEM 18th Exhibition · Networking Break</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">13:30–15:00</div>
                    <div class="schedule-event">Session 1 — Materials Sciences, Green Technologies and Sustainable Energy Conversion (Part 2)</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">15:00–15:30</div>
                    <div class="schedule-event">Session 2 — Regional Initiatives for Environment Preservation and Sustainability</div>
                </div>

                <div class="schedule-item">
                    <div class="schedule-time">15:30–15:40</div>
                    <div class="schedule-event">Wrap-up of the Day</div>
                </div>

                <div class="schedule-item evening-item">
                    <div class="schedule-time">19:00</div>
                    <div class="schedule-event">Gala Dinner</div>
                </div>
            </div>

            <!-- DAY 2 -->
            <div class="schedule-day">
                <div class="schedule-day-head">
                    <div class="schedule-day-label">Day 2</div>
                    <div class="schedule-day-theme">People, Places, and Participatory Solutions</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">09:00–10:30</div>
                    <div class="schedule-event">Session 3 — Heritage Conservation and Environmental Initiatives</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">10:30–10:50</div>
                    <div class="schedule-event">Coffee Break</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">10:50–12:20</div>
                    <div class="schedule-event">Session 4 — Molecular Design &amp; Resilience (Part 1)</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">12:20–13:10</div>
                    <div class="schedule-event">Lunch Break</div>
                </div>

                <div class="schedule-item poster-item">
                    <div class="schedule-time">13:10–14:45</div>
                    <div class="schedule-event">Poster Session 2 · Interactive Discussions · ROMPHYSCHEM 18th Exhibition</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">13:10–14:40</div>
                    <div class="schedule-event">Session 4 — Molecular Design &amp; Resilience (Part 2)</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">14:40–15:15</div>
                    <div class="schedule-event">Session 5 — Future of Ecosystem Solutions</div>
                </div>

                <div class="schedule-item">
                    <div class="schedule-time">15:15–15:30</div>
                    <div class="schedule-event">Wrap-up of the Day</div>
                </div>
            </div>

            <!-- DAY 3 -->
            <div class="schedule-day">
                <div class="schedule-day-head">
                    <div class="schedule-day-label">Day 3</div>
                    <div class="schedule-day-theme">Innovation, Impact, and Integration</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">09:00–10:30</div>
                    <div class="schedule-event">Session 6 — Sustainable Innovation &amp; Circular Economy Panel</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">10:30–10:50</div>
                    <div class="schedule-event">Coffee Break</div>
                </div>

                <div class="schedule-item poster-item">
                    <div class="schedule-time">10:50–12:00</div>
                    <div class="schedule-event">Poster Session 3 — Solution Showcase &amp; Interactive Discussions</div>
                </div>

                <div class="schedule-item break-item">
                    <div class="schedule-time">12:00–12:50</div>
                    <div class="schedule-event">Lunch Break</div>
                </div>

                <div class="schedule-item featured">
                    <div class="schedule-time">12:50–14:10</div>
                    <div class="schedule-event">High-Level Round Table — Stakeholders for a Just and Sustainable Future</div>
                </div>

                <div class="schedule-item">
                    <div class="schedule-time">14:10–14:30</div>
                    <div class="schedule-event">Closing Session</div>
                </div>
            </div>

        </div>
    </div>
</section>

<style>
    /* Page shell */
    .schedule-page {
        background: #f8fbfd;
    }

    .schedule-header {
        max-width: 900px;
        margin-left: auto;
        margin-right: auto;
    }

    .schedule-title {
        color: var(--conference-blue);
        font-weight: 700;
        margin-bottom: 0.75rem;
    }

    .schedule-subtitle {
        color: #5d7695;
        font-size: 1.05rem;
    }

    /* Board layout */
    .schedule-board {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 1.5rem;
        align-items: start;
    }

    .schedule-day {
        background: #ffffff;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 10px 28px rgba(31, 78, 140, 0.08);
        border: 1px solid rgba(31, 78, 140, 0.08);
    }

    .schedule-day-head {
        background: linear-gradient(to right, #d6eef8, #edf8fc);
        padding: 1.2rem 1.2rem 1rem 1.2rem;
        border-bottom: 1px solid rgba(31, 78, 140, 0.08);
    }

    .schedule-day-label {
        font-size: 0.9rem;
        font-weight: 700;
        color: #b88a16;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-bottom: 0.35rem;
    }

    .schedule-day-theme {
        font-size: 1.2rem;
        font-weight: 700;
        color: var(--conference-blue);
        line-height: 1.3;
    }

    /* Items */
    .schedule-item {
        padding: 1rem 1.2rem;
        border-bottom: 1px solid rgba(31, 78, 140, 0.08);
    }

        .schedule-item:last-child {
            border-bottom: none;
        }

    .schedule-time {
        font-size: 0.92rem;
        font-weight: 700;
        color: #b88a16;
        margin-bottom: 0.35rem;
    }

    .schedule-event {
        color: #294a73;
        font-weight: 600;
        line-height: 1.45;
    }

    /* Main sessions */
    .schedule-item.featured {
        background: rgba(214, 238, 248, 0.45);
    }

    /* Poster sessions */
    .poster-item {
        background: linear-gradient(to right, rgba(167, 213, 232, 0.95), rgba(196, 229, 242, 0.90));
    }

        .poster-item .schedule-time {
            color: #1f4e8c;
        }

        .poster-item .schedule-event {
            color: #163a69;
            font-weight: 700;
        }

    /* Breaks and special items */
    .schedule-item.break-item .schedule-event {
        font-weight: 500;
        color: #617b98;
    }

    .schedule-item.evening-item {
        background: rgba(217, 180, 74, 0.10);
    }

    /* Responsive */
    @@media (max-width: 991.98px) {
        .schedule-board {
            grid-template-columns: 1fr;
        }

        .schedule-day-theme {
            font-size: 1.08rem;
        }

        .schedule-event {
            font-size: 0.98rem;
        }
    }

    @@media (min-width: 992px) {
        .schedule-title {
            font-size: 2.8rem;
        }

        .schedule-subtitle {
            font-size: 1.15rem;
        }

        .schedule-event {
            font-size: 1.05rem;
        }
    }
</style>