@page
@model ConferenceSite.Pages.Conference.SpeakersModel
@{
    ViewData["Title"] = "Speakers";
}

<style>
    .speakers-wrapper {
        background: #f3f6f8;
        padding: 48px 20px 80px;
    }

    .speakers-container {
        max-width: 1280px;
        margin: 0 auto;
    }

    .speakers-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .speakers-header h1 {
            margin: 0 0 10px;
            font-size: 3rem;
            line-height: 1.1;
            font-weight: 800;
            color: #1e4f91;
            letter-spacing: -0.02em;
        }

        .speakers-header p {
            margin: 0;
            font-size: 1.2rem;
            color: #5d7696;
            line-height: 1.6;
        }

    .speakers-intro {
        background: #dfeaf1;
        border: 1px solid #d3e1ea;
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 34px;
        box-shadow: 0 8px 24px rgba(30, 79, 145, 0.05);
    }

        .speakers-intro h2 {
            margin: 0 0 10px;
            font-size: 1.45rem;
            font-weight: 800;
            color: #1e4f91;
        }

        .speakers-intro p {
            margin: 0;
            font-size: 1.02rem;
            line-height: 1.8;
            color: #294768;
        }

    .speakers-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .speaker-card {
        background: #dfeaf1;
        border: 1px solid #d3e1ea;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(30, 79, 145, 0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .speaker-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        display: block;
        background: #cfdde8;
    }

    .speaker-content {
        background: #f8fbfd;
        padding: 22px 22px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .speaker-role {
        display: inline-block;
        margin-bottom: 10px;
        font-size: 0.88rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #c58a00;
    }

    .speaker-name {
        margin: 0 0 8px;
        font-size: 1.4rem;
        line-height: 1.3;
        font-weight: 800;
        color: #1e4f91;
    }

    .speaker-affiliation {
        margin: 0 0 14px;
        font-size: 1rem;
        line-height: 1.6;
        color: #5d7696;
        font-weight: 600;
    }

    .speaker-bio {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.8;
        color: #294768;
    }

    @@media (max-width: 992px) {
        .speakers-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .speakers-header h1 {
            font-size: 2.4rem;
        }
    }

    @@media (max-width: 768px) {
        .speakers-grid {
            grid-template-columns: 1fr;
        }

        .speakers-wrapper {
            padding: 36px 14px 60px;
        }

        .speakers-header h1 {
            font-size: 2rem;
        }

        .speakers-header p {
            font-size: 1.02rem;
        }

        .speakers-intro {
            padding: 22px 20px;
        }

        .speaker-content {
            padding: 18px 18px 20px;
        }
    }
</style>

<div class="speakers-wrapper">
    <div class="speakers-container">

        <section class="speakers-header">
            <h1>Speakers</h1>
            <p>23–25 September 2026 · Bucharest, Romanian Academy</p>
        </section>

        <section class="speakers-intro">
            <h2>Invited speakers and featured contributors</h2>
            <p>
                The conference brings together distinguished researchers, professionals, and institutional
                representatives working across interdisciplinary domains. Below is a preliminary speakers
                section template that can be updated with confirmed names, affiliations, biographies,
                and presentation details.
            </p>
        </section>

        <section class="speakers-grid">
            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+1" alt="Speaker 1">
                <div class="speaker-content">
                    <span class="speaker-role">Japan</span>
                    <h3 class="speaker-name">Prof. K-I. Aika</h3>
                    <p class="speaker-affiliation">National Institute of Technology (KOSEN), Numazu College</p>
                    <p class="speaker-bio">
                        Prof. K-I. Aika is a renowned expert in catalysis and sustainable energy, specializing in ammonia synthesis as a clean energy carrier. 
                        At the Green Ammonia Research Center, he leads research on low-carbon ammonia production and hydrogen-based energy systems, contributing to global decarbonization efforts.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+2" alt="Speaker 2">
                <div class="speaker-content">
                    <span class="speaker-role">Japan</span>
                    <h3 class="speaker-name">Prof. A. Kudo</h3>
                    <p class="speaker-affiliation">
                        Tokyo University of Science, Department of Applied Chemistry
                        Carbon Value Research Center
                    </p>
                    <p class="speaker-bio">
                        Prof. Akihiko Kudo is a leading researcher in photocatalysis and solar energy conversion, known for his pioneering work on water splitting and hydrogen production. 
                        His research focuses on developing advanced materials for efficient solar-to-chemical energy conversion, contributing to sustainable energy solutions and carbon-neutral technologies.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+3" alt="Speaker 3">
                <div class="speaker-content">
                    <span class="speaker-role">Japan</span>
                    <h3 class="speaker-name">Prof. Y. Izumi</h3>
                    <p class="speaker-affiliation">Chiba University</p>
                    <p class="speaker-bio">
                        Prof. Y. Izumi is an expert in catalysis and sustainable chemistry, with research focused on photocatalysis, CO₂ utilization, and green energy processes. 
                        His work advances catalytic systems for environmental applications and supports the development of low-carbon energy technologies.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+4" alt="Speaker 4">
                <div class="speaker-content">
                    <span class="speaker-role">Japan</span>
                    <h3 class="speaker-name">Dr. Taketoshi Minato</h3>
                    <p class="speaker-affiliation">Institute for Molecular Science, National Institutes of Natural Sciences</p>
                    <p class="speaker-bio">
                        Dr. Taketoshi Minato is a researcher in surface science and catalysis, specializing in the atomic-scale understanding of catalytic materials. 
                        His work focuses on reaction mechanisms, surface interactions, and the design of efficient catalysts for energy and environmental applications.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+5" alt="Speaker 5">
                <div class="speaker-content">
                    <span class="speaker-role">Japan</span>
                    <h3 class="speaker-name">Prof. J. Ryu</h3>
                    <p class="speaker-affiliation">
