@page
@model ConferenceSite.Pages.Conference.SpeakersModel
@{
    ViewData["Title"] = "Speakers";
}

<style>
    .speakers-wrapper {
        background: #f3f6f8;
        padding: 48px 20px 80px;
    }

    .speakers-container {
        max-width: 1280px;
        margin: 0 auto;
    }

    .speakers-header {
        text-align: center;
        margin-bottom: 40px;
    }

        .speakers-header h1 {
            margin: 0 0 10px;
            font-size: 3rem;
            line-height: 1.1;
            font-weight: 800;
            color: #1e4f91;
            letter-spacing: -0.02em;
        }

        .speakers-header p {
            margin: 0;
            font-size: 1.2rem;
            color: #5d7696;
            line-height: 1.6;
        }

    .speakers-intro {
        background: #dfeaf1;
        border: 1px solid #d3e1ea;
        border-radius: 24px;
        padding: 28px 30px;
        margin-bottom: 34px;
        box-shadow: 0 8px 24px rgba(30, 79, 145, 0.05);
    }

        .speakers-intro h2 {
            margin: 0 0 10px;
            font-size: 1.45rem;
            font-weight: 800;
            color: #1e4f91;
        }

        .speakers-intro p {
            margin: 0;
            font-size: 1.02rem;
            line-height: 1.8;
            color: #294768;
        }

    .speakers-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 24px;
    }

    .speaker-card {
        background: #dfeaf1;
        border: 1px solid #d3e1ea;
        border-radius: 22px;
        overflow: hidden;
        box-shadow: 0 8px 24px rgba(30, 79, 145, 0.05);
        display: flex;
        flex-direction: column;
        height: 100%;
    }

    .speaker-image {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        display: block;
        background: #cfdde8;
    }

    .speaker-content {
        background: #f8fbfd;
        padding: 22px 22px 24px;
        flex: 1;
        display: flex;
        flex-direction: column;
    }

    .speaker-role {
        display: inline-block;
        margin-bottom: 10px;
        font-size: 0.88rem;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #c58a00;
    }

    .speaker-name {
        margin: 0 0 8px;
        font-size: 1.4rem;
        line-height: 1.3;
        font-weight: 800;
        color: #1e4f91;
    }

    .speaker-affiliation {
        margin: 0 0 14px;
        font-size: 1rem;
        line-height: 1.6;
        color: #5d7696;
        font-weight: 600;
    }

    .speaker-bio {
        margin: 0;
        font-size: 0.98rem;
        line-height: 1.8;
        color: #294768;
    }

    @@media (max-width: 992px) {
        .speakers-grid {
            grid-template-columns: repeat(2, 1fr);
        }

        .speakers-header h1 {
            font-size: 2.4rem;
        }
    }

    @@media (max-width: 768px) {
        .speakers-grid {
            grid-template-columns: 1fr;
        }

        .speakers-wrapper {
            padding: 36px 14px 60px;
        }

        .speakers-header h1 {
            font-size: 2rem;
        }

        .speakers-header p {
            font-size: 1.02rem;
        }

        .speakers-intro {
            padding: 22px 20px;
        }

        .speaker-content {
            padding: 18px 18px 20px;
        }
    }
</style>

<div class="speakers-wrapper">
    <div class="speakers-container">

        <section class="speakers-header">
            <h1>Speakers</h1>
            <p>23–25 September 2026 · Bucharest, Romanian Academy</p>
        </section>

        <section class="speakers-intro">
            <h2>Invited speakers and featured contributors</h2>
            <p>
                The conference brings together distinguished researchers, professionals, and institutional
                representatives working across interdisciplinary domains. Below is a preliminary speakers
                section template that can be updated with confirmed names, affiliations, biographies,
                and presentation details.
            </p>
        </section>

        <section class="speakers-grid">
            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+1" alt="Speaker 1">
                <div class="speaker-content">
                    <span class="speaker-role">Keynote Speaker</span>
                    <h3 class="speaker-name">Dr. Alexandra Marin</h3>
                    <p class="speaker-affiliation">University of Bucharest, Romania</p>
                    <p class="speaker-bio">
                        Dr. Alexandra Marin is a researcher in environmental systems and science-policy
                        collaboration, with extensive experience in interdisciplinary research and public engagement.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+2" alt="Speaker 2">
                <div class="speaker-content">
                    <span class="speaker-role">Invited Speaker</span>
                    <h3 class="speaker-name">Prof. Daniel Ionescu</h3>
                    <p class="speaker-affiliation">Technical University of Cluj-Napoca, Romania</p>
                    <p class="speaker-bio">
                        Prof. Daniel Ionescu focuses on advanced materials and sustainable technologies,
                        contributing to several international collaborations in applied research and innovation.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+3" alt="Speaker 3">
                <div class="speaker-content">
                    <span class="speaker-role">Panel Speaker</span>
                    <h3 class="speaker-name">Dr. Elena Popescu</h3>
                    <p class="speaker-affiliation">National Institute for Research and Development, Romania</p>
                    <p class="speaker-bio">
                        Dr. Elena Popescu works on institutional innovation and research infrastructures,
                        with a particular interest in transnational cooperation and capacity building.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+4" alt="Speaker 4">
                <div class="speaker-content">
                    <span class="speaker-role">Guest Speaker</span>
                    <h3 class="speaker-name">Prof. Mihai Stănescu</h3>
                    <p class="speaker-affiliation">Alexandru Ioan Cuza University, Iași, Romania</p>
                    <p class="speaker-bio">
                        Prof. Mihai Stănescu is known for his work in innovation ecosystems, regional development,
                        and the interface between academic research and societal impact.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+5" alt="Speaker 5">
                <div class="speaker-content">
                    <span class="speaker-role">Invited Speaker</span>
                    <h3 class="speaker-name">Dr. Cristina Pavel</h3>
                    <p class="speaker-affiliation">Romanian Academy, Romania</p>
                    <p class="speaker-bio">
                        Dr. Cristina Pavel conducts research in interdisciplinary analytical frameworks and
                        contributes to initiatives supporting scientific excellence and institutional reform.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+6" alt="Speaker 6">
                <div class="speaker-content">
                    <span class="speaker-role">Featured Speaker</span>
                    <h3 class="speaker-name">Prof. Andrei Dumitrescu</h3>
                    <p class="speaker-affiliation">University Politehnica of Bucharest, Romania</p>
                    <p class="speaker-bio">
                        Prof. Andrei Dumitrescu specializes in technological innovation, industrial partnerships,
                        and the strategic development of collaborative research environments.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+7" alt="Speaker 7">
                <div class="speaker-content">
                    <span class="speaker-role">Panel Speaker</span>
                    <h3 class="speaker-name">Dr. Irina Georgescu</h3>
                    <p class="speaker-affiliation">Institute of Chemistry, Romania</p>
                    <p class="speaker-bio">
                        Dr. Irina Georgescu works in advanced characterization methods and has contributed to
                        multiple research projects involving international partnerships and knowledge transfer.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+8" alt="Speaker 8">
                <div class="speaker-content">
                    <span class="speaker-role">Guest Speaker</span>
                    <h3 class="speaker-name">Prof. Radu Muntean</h3>
                    <p class="speaker-affiliation">West University of Timișoara, Romania</p>
                    <p class="speaker-bio">
                        Prof. Radu Muntean has extensive expertise in interdisciplinary education, scientific
                        networking, and the development of collaborative research communities.
                    </p>
                </div>
            </article>

            <article class="speaker-card">
                <img class="speaker-image" src="https://via.placeholder.com/600x450?text=Speaker+9" alt="Speaker 9">
                <div class="speaker-content">
                    <span class="speaker-role">Invited Speaker</span>
                    <h3 class="speaker-name">Dr. Sorina Neagu</h3>
                    <p class="speaker-affiliation">National University of Science and Technology, Romania</p>
                    <p class="speaker-bio">
                        Dr. Sorina Neagu is engaged in research management, international cooperation,
                        and the design of initiatives supporting innovation, training, and institutional visibility.
                    </p>
                </div>
            </article>
        </section>

    </div>
</div>